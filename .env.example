VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side key for local backups (npm run backup) — dashboard -> Settings -> API.
# No VITE_ prefix on purpose: Vite must never bundle this into the client.
SUPABASE_SERVICE_ROLE_KEY=

# Sentry error reporting (optional — leave empty for no error tracking)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
